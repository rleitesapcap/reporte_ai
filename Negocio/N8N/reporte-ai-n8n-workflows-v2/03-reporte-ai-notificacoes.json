        "jsonBody": "={\n  \"number\": \"{{ $json.phone }}\",\n  \"text\": {{ JSON.stringify($json.text) }},\n  \"delay\": 1000\n}",
        "options": {}
      },
      "id": "b1b2c3d4-bbbb-4bbb-8bbb-bbbbbbbbbbbb",
