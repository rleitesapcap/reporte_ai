      "id": "b1b2c3d4-9999-4999-8999-999999999999",
      "name": "Check Evolution",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 800],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const resp = $input.item.json;\nconst state = (resp.instance && resp.instance.state) ? resp.instance.state : 'unknown';\nconst ADMIN = $env.ADMIN_PHONE || '';\n\nif (state === 'open' || !ADMIN) return [];\n\nreturn {\n  phone: ADMIN,\n  text: '\\ud83d\\udea8 *ALERTA CR\\u00cdTICO*\\n\\nWhatsApp do Reporte AI est\\u00e1 *DESCONECTADO*.\\nEstado: ' + state + '\\n\\nAcesse o Evolution Manager para reconectar.'\n};"
      },
